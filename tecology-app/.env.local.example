# Copia este archivo como `.env.local` y pega tus claves de Supabase.
# (Settings → API en el panel de Supabase). Son claves públicas: seguras de exponer.
# Si dejas estas variables vacías, la app funciona en modo demo local (localStorage).

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# ---------------------------------------------------------------------------
# Opcional: cotizaciones reales en Zoho Books. Sin esto, "Solicitar cotización"
# sigue funcionando (guarda el lead) pero no genera un PDF de Zoho.
# Consigue estos valores desde /admin → pestaña "Cotizaciones (Zoho)", o
# manualmente en https://api-console.zoho.com (Self Client). Estos SÍ son
# secretos — nunca los pongas en NEXT_PUBLIC_*, solo se usan en el servidor.
# ---------------------------------------------------------------------------
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
# ID del impuesto (ej. ITBMS) a aplicar en cada línea de la cotización.
ZOHO_TAX_ID=
# Opcional: si tu Zoho exige "Vendedor" y quieres fijar uno específico. Si lo
# dejas vacío, se usa automáticamente el primer vendedor de la cuenta.
ZOHO_SALESPERSON_ID=
# Solo si tu cuenta Zoho usa un centro de datos distinto al global (.com):
# ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
# ZOHO_API_DOMAIN=https://www.zohoapis.com
