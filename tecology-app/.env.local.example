# Copia este archivo como `.env.local` y pega tus claves de Supabase.
# (Settings → API en el panel de Supabase). Son claves públicas: seguras de exponer.
# Si dejas estas variables vacías, la app funciona en modo demo local (localStorage).

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY
